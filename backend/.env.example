ENVIRONMENT=development
DATABASE_URL=sqlite:///./chiefflow.db
JWT_SECRET=change-me-in-production

# All optional — ChiefFlow AI falls back to the local reasoning engine
# for any tier that isn't configured, so it runs fully offline by default.
GEMMA_API_URL=
GEMMA_API_KEY=
GEMMA_MODEL=gemma2-9b-it

AMD_GPU_API_URL=
AMD_GPU_API_KEY=
AMD_GPU_MODEL=llama-3.1-8b-instruct

FIREWORKS_API_URL=https://api.fireworks.ai/inference/v1/chat/completions
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct

CORS_ORIGINS=["http://localhost:3000"]
